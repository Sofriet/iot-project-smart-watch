import os
import glob
import pandas as pd
import numpy as np

files = glob.glob(os.path.join(DATA_DIR, "*.csv"))

lengths = []

for f in files:
    df = pd.read_csv(f)
    lengths.append(len(df))

print("Minimum:", np.min(lengths))
print("Average:", np.mean(lengths))
print("Maximum:", np.max(lengths))